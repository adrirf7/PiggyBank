rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read/write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Each user can read/write any subcollection (transactions, goals, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
